# ============================================================
# Robinhood Sniper Bot configuration
# Copy to .env and fill in. NEVER commit your real .env.
# Start with MODE=paper, then MODE=testnet, only then live.
# ============================================================

# --- Chain -------------------------------------------------
# Robinhood Chain mainnet: chain id 4663,  https://rpc.mainnet.chain.robinhood.com/
# Robinhood Chain testnet: chain id 46630, https://rpc.testnet.chain.robinhood.com
ROBINHOOD_RPC_URL=https://rpc.testnet.chain.robinhood.com
# Optional WebSocket endpoint (falls back to HTTP polling if unset)
ROBINHOOD_WS_URL=
CHAIN_ID=46630

# --- Wallet ------------------------------------------------
# Hex private key (0x-prefixed). Required only for testnet/live trading.
# NEVER share this. It is never logged and never stored in the database.
PRIVATE_KEY=
# Optional: expected wallet address; if set, it is cross-checked against PRIVATE_KEY.
WALLET_ADDRESS=

# --- Mode --------------------------------------------------
# paper   = no chain writes, simulated fills (works out of the box with DEX_TYPE=mock)
# testnet = real transactions on Robinhood Chain testnet
# live    = real money. Requires ENABLE_LIVE_TRADING=true AND `bot confirm-live`.
MODE=paper

# --- DEX ---------------------------------------------------
# uniswap_v2 | uniswap_v3 | mock
DEX_TYPE=mock
# >>> PASTE the real Robinhood Chain DEX factory address here (0x...) <<<
DEX_FACTORY_ADDRESS=
# >>> PASTE the real Robinhood Chain DEX router address here (0x...) <<<
DEX_ROUTER_ADDRESS=
# Uniswap v3 only: QuoterV2 contract address
DEX_QUOTER_ADDRESS=
# Base/quote token the bot trades against (e.g. WETH or USDG on Robinhood Chain)
# >>> PASTE the base token address here (0x...) <<<
BASE_TOKEN_ADDRESS=
# true if BASE_TOKEN_ADDRESS is the wrapped native token (WETH-style) and the bot
# should pay with native ETH; false to trade ERC20<->ERC20 (requires base token balance)
BASE_TOKEN_IS_NATIVE_WRAPPER=true

# --- Risk limits (all enforced before every trade) ---------
# Size of each buy, in ETH (also the hard per-trade cap)
MAX_BUY_ETH=0.01
# Max slippage in basis points (100 = 1%)
MAX_SLIPPAGE_BPS=300
# Abort any tx whose max fee exceeds this (gwei)
MAX_GAS_GWEI=5
# Skip pools with less than this much base-token liquidity (in ETH units)
MIN_LIQUIDITY_ETH=1
# Skip tokens whose estimated buy+sell tax exceeds this (basis points)
MAX_TOKEN_TAX_BPS=1000
# Auto-sell when position is up this % ...
TAKE_PROFIT_PERCENT=50
# ... or down this %
STOP_LOSS_PERCENT=20
# Optional: exit if price falls this % from its post-entry high (blank = disabled)
TRAILING_STOP_PERCENT=
# Never hold more than this many open positions
MAX_OPEN_POSITIONS=3
# Wait at least this long between buys (seconds)
COOLDOWN_SECONDS=60

# --- Live-trading master switch ----------------------------
# Even with MODE=live, no live order is sent unless this is true
# AND you have run `npm run bot -- confirm-live` in the CLI.
ENABLE_LIVE_TRADING=false

# --- Misc --------------------------------------------------
# SQLite database file
DB_PATH=./data/bot.db
# debug | info | warn | error
LOG_LEVEL=info
# Starting balance for paper mode (ETH)
PAPER_BALANCE_ETH=10
# Position price-check interval (ms)
POSITION_POLL_MS=5000
